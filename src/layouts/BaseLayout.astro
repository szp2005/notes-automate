---
interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  pubDate?: string;
  isArticle?: boolean;
  noindex?: boolean;
  dateModified?: string;
  author?: string;
  articleImage?: string;
}
const {
  title = 'Obsidian Plugins Guide',
  description = 'The best Obsidian plugins, themes, and tips to supercharge your note-taking.',
  canonicalURL: canonicalURLProp,
  pubDate,
  isArticle = false,
  noindex = false,
  dateModified,
  author,
  articleImage,
} = Astro.props;

const siteName = 'Obsidian Plugins Guide';
const siteURL = 'https://notes-automate.com';
const siteSlug = 'notes-automate';

// Locale-aware nav links
const isZhCn = Astro.url.pathname.startsWith('/zh-cn/');
const localePrefix = isZhCn ? '/zh-cn' : '';

// i18n logic
const { pathname } = Astro.url;
const lang = pathname.startsWith('/zh-cn') ? 'zh-cn' : 'en';

// Force canonical to siteURL host regardless of which domain served the page.
const canonicalURL = canonicalURLProp ?? `${siteURL}${pathname}${Astro.url.search}`;

const normalizedPath = pathname.replace(/^\/zh-cn/, '') || '/';
const pathWithTrailingSlash = normalizedPath.endsWith('/') ? normalizedPath : `${normalizedPath}/`;
const hasLocalizedStaticPage = new Set(['/', '/about/', '/contact/', '/privacy/', '/posts/']).has(pathWithTrailingSlash);
const hasLocalizedPostPage = /^\/posts\/[^/]+\/$/.test(pathWithTrailingSlash);
const shouldEmitLocalizedAlternates = !noindex && (hasLocalizedStaticPage || hasLocalizedPostPage);
const alternateEn = `${siteURL}${pathWithTrailingSlash}`;
const alternateZh = `${siteURL}${pathWithTrailingSlash === '/' ? '/zh-cn/' : `/zh-cn${pathWithTrailingSlash}`}`;

const ogImage = articleImage ? (articleImage.startsWith('http') ? articleImage : `${siteURL}${articleImage}`) : `${siteURL}/og-default.png`;
const cloudflareWebAnalyticsToken = import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN;
const hasCloudflareWebAnalyticsToken =
  typeof cloudflareWebAnalyticsToken === 'string' &&
  /^[0-9a-f]{32}$/i.test(cloudflareWebAnalyticsToken);
const adsensePublisherId = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID;
const ga4MeasurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#7c3aed" />
    <meta name="color-scheme" content="light" />
    <meta name="google-site-verification" content="oSL2rs6gCuiuPagtD4cvuKjkigSMoaQWIXj8fkHCckI" />
    <meta name="description" content={description} />
    <title>{title}</title>
    {noindex && (<meta name="robots" content="noindex,follow" />)}

    {shouldEmitLocalizedAlternates && (
      <>
        <!-- i18n -->
        <link rel="alternate" hreflang="en" href={alternateEn} />
        <link rel="alternate" hreflang="zh-cn" href={alternateZh} />
        <link rel="alternate" hreflang="x-default" href={alternateEn} />
      </>
    )}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="Obsidian Plugins Guide RSS Feed" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org Article -->
    {isArticle && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "datePublished": pubDate,
        "dateModified": dateModified ?? pubDate,
        "image": articleImage ?? ogImage,
        "inLanguage": lang,
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalURL
        },
        "author": {
          "@type": "Person",
          "name": author ?? "Editorial Team",
          "url": `${siteURL}/about/`
        },
        "publisher": {
          "@type": "Organization",
          "name": siteName,
          "url": siteURL,
          "logo": {
            "@type": "ImageObject",
            "url": ogImage
          }
        }
      })} />
    )}

    <!-- Schema.org Breadcrumb -->
    {isArticle && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": siteURL },
          { "@type": "ListItem", "position": 2, "name": "Posts", "item": `${siteURL}/posts/` },
          { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL }
        ]
      })} />
    )}

    <!-- Schema.org WebSite (homepage only) -->
    {!isArticle && Astro.url.pathname === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": siteName,
        "url": siteURL,
        "description": description,
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": `${siteURL}/search/?q={search_term_string}`
          },
          "query-input": "required name=search_term_string"
        }
      })} />
    )}

    <link rel="stylesheet" href="/styles/global.css" />
    {hasCloudflareWebAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cloudflareWebAnalyticsToken })}
      ></script>
    )}
    {adsensePublisherId && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsensePublisherId}`}
        crossorigin="anonymous"
      ></script>
    )}
    {adsensePublisherId && (
      <meta name="google-adsense-account" content={adsensePublisherId} />
    )}
    {ga4MeasurementId && (
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`}></script>
    )}
    {ga4MeasurementId && (
      <script is:inline set:html={`window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', '${ga4MeasurementId}', { anonymize_ip: true });`} />
    )}
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={isZhCn ? "/zh-cn/" : "/"}>Obsidian Plugins Guide</a>
      <nav>
        <a href={`${localePrefix}/posts/`}>Guides</a>
        <a href={`${localePrefix}/about/`}>About</a>
        <a href="/author/">Authors</a>
        <a href="/tags/">Tags</a>
        <a href="/search/">Search</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Independent guides and reviews for Obsidian plugins, themes, and workflows.</p>
      <nav class="footer-nav">
        <a href={`${localePrefix}/about/`}>About</a>
        <a href={`${localePrefix}/contact/`}>Contact</a>
        <a href={`${localePrefix}/privacy/`}>Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="/affiliate-disclosure/">Affiliate Disclosure</a>
        <a href="/editorial-policy/">Editorial Policy</a>
        <a href={`${localePrefix}/posts/`}>All Posts</a>
        <a href="/author/">Authors</a>
        <a href="/tags/">Tags</a>
        <a href="/rss.xml">RSS</a>
        <a
          href={`https://tools.toolrouteai.com/?ref=${siteSlug}`}
          target="_blank"
          rel="noopener nofollow"
          style="display:inline-flex;align-items:center;gap:.4rem;font-size:.9rem;color:#7c3aed;text-decoration:none;"
        >
          📬 Free AI tools + Weekly digest →
        </a>
        <a
          href={`https://tools.toolrouteai.com/obsidian-template-generator/project?ref=${siteSlug}`}
          target="_blank"
          rel="noopener nofollow"
          style="display:inline-flex;align-items:center;gap:.4rem;font-size:.9rem;color:#7c3aed;text-decoration:none;"
        >
          Obsidian template generator →
        </a>
      </nav>
    </footer>
    <div id="cookie-consent" class="cookie-consent" hidden>
      <p>We use privacy-minded analytics, advertising scripts, and affiliate tracking to keep this site free. By continuing, you agree to our <a href="/privacy/">Privacy Policy</a> and <a href="/terms/">Terms</a>.</p>
      <button type="button" id="cookie-consent-accept">Accept</button>
    </div>
    <script is:inline>
      (() => {
        const banner = document.getElementById('cookie-consent');
        const button = document.getElementById('cookie-consent-accept');
        if (!banner || !button) return;
        if (localStorage.getItem('cookie-consent-v1') === 'accepted') return;
        banner.hidden = false;
        button.addEventListener('click', () => {
          localStorage.setItem('cookie-consent-v1', 'accepted');
          banner.hidden = true;
        });
      })();
    </script>
  </body>
</html>
