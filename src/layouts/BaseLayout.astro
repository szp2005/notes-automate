---
interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  pubDate?: string;
  isArticle?: boolean;
  noindex?: boolean;
  dateModified?: string;
  author?: string;
  articleImage?: string;
}
const {
  title = 'Obsidian Plugins Guide',
  description = 'The best Obsidian plugins, themes, and tips to supercharge your note-taking.',
  canonicalURL = Astro.url.href,
  pubDate,
  isArticle = false,
  noindex = false,
  dateModified,
  author,
  articleImage,
} = Astro.props;
const siteName = 'Obsidian Plugins Guide';
const siteURL = 'https://notes-automate.com';
const ogImage = articleImage ? (articleImage.startsWith('http') ? articleImage : `${siteURL}${articleImage}`) : `${siteURL}/og-default.png`;
const cloudflareWebAnalyticsToken = import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN;
const adsensePublisherId = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID;
const ga4MeasurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#7c3aed" />
    <meta name="color-scheme" content="light" />
    <meta name="google-site-verification" content="oSL2rs6gCuiuPagtD4cvuKjkigSMoaQWIXj8fkHCckI" />
    <meta name="description" content={description} />
    <title>{title}</title>
    {noindex && (<meta name="robots" content="noindex,follow" />)}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="Obsidian Plugins Guide RSS Feed" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org Article -->
    {isArticle && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "datePublished": pubDate,
        "dateModified": dateModified ?? pubDate,
        "image": articleImage ?? ogImage,
        "inLanguage": "en",
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalURL
        },
        "author": {
          "@type": "Person",
          "name": author ?? "Editorial Team",
          "url": `${siteURL}/about/`
        },
        "publisher": {
          "@type": "Organization",
          "name": siteName,
          "url": siteURL,
          "logo": {
            "@type": "ImageObject",
            "url": ogImage
          }
        }
      })} />
    )}

    <!-- Schema.org Breadcrumb -->
    {isArticle && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": siteURL },
          { "@type": "ListItem", "position": 2, "name": "Posts", "item": `${siteURL}/posts/` },
          { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL }
        ]
      })} />
    )}

    <!-- Schema.org WebSite (homepage only) -->
    {!isArticle && Astro.url.pathname === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": siteName,
        "url": siteURL,
        "description": description,
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": `${siteURL}/search/?q={search_term_string}`
          },
          "query-input": "required name=search_term_string"
        }
      })} />
    )}

    <link rel="stylesheet" href="/styles/global.css" />
    {cloudflareWebAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cloudflareWebAnalyticsToken })}
      ></script>
    )}
    {adsensePublisherId && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsensePublisherId}`}
        crossorigin="anonymous"
      ></script>
    )}
    {adsensePublisherId && (
      <meta name="google-adsense-account" content={adsensePublisherId} />
    )}
    {ga4MeasurementId && (
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`}></script>
    )}
    {ga4MeasurementId && (
      <script is:inline set:html={`window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', '${ga4MeasurementId}', { anonymize_ip: true });`} />
    )}
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Obsidian Plugins Guide</a>
      <nav>
        <a href="/posts/">Guides</a>
        <a href="/about/">About</a>
        <a href="/tags/">Tags</a>
        <a href="/search/">Search</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Independent guides and reviews for Obsidian plugins, themes, and workflows.</p>
      <nav class="footer-nav">
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
        <a href="/privacy/">Privacy</a>
        <a href="/posts/">All Posts</a>
        <a href="/tags/">Tags</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </footer>
  </body>
</html>
