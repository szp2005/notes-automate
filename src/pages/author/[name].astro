---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {{
  const modules = import.meta.glob('../../../content/posts/*.md', {{ eager: true }});
  const posts = Object.entries(modules).map(([path, mod]) => ({{
    frontmatter: (mod as any).frontmatter ?? {{}},
    slug: (mod as any).frontmatter.slug ?? path.split('/').pop()?.replace(/\.md$/, ''),
  }}));

  const authors = [...new Set(posts.map(p => p.frontmatter.author).filter(Boolean))];
  
  return authors.map(author => {{
    const authorPosts = posts.filter(p => p.frontmatter.author === author);
    return {{
      params: {{ name: author.toLowerCase().replace(/\s+/g, '-') }},
      props: {{ author, posts: authorPosts }}
    }};
  }});
}}

const {{ author, posts }} = Astro.props;
const siteName = 'Notes Automate';

const bios: Record<string, string> = {{
  "Alex Chen": "Alex Chen is a dedicated AI and PKM (Personal Knowledge Management) researcher with over a decade of experience in digital productivity systems. He specializes in bridging the gap between cutting-edge LLMs and practical daily workflows, helping professionals build 'Second Brains' that actually work.",
  "Sarah Miller": "Sarah Miller is a certified ergonomist and home office design consultant. With a background in physical therapy, she focuses on helping remote workers create healthy, productive workspaces that prevent strain and boost long-term well-being."
}};

const bio = bios[author] || `Expert contributor at ${{siteName}}, specializing in deep-dive research and practical guides.`;
---
<BaseLayout title={`Articles by ${{author}} | ${{siteName}}`} description={`Read all articles and guides written by ${{author}} on ${{siteName}}.`}>
  <div class="author-page">
    <header class="author-header">
      <div class="author-info">
        <h1>{{author}}</h1>
        <p class="bio">{{bio}}</p>
      </div>
    </header>

    <section class="author-posts">
      <h2>Published Articles</h2>
      <ul class="post-list">
        {{posts.map(post => (
          <li>
            <a href={`/posts/${{post.slug}}/`}>{{post.frontmatter.title}}</a>
            <span class="date">{{post.frontmatter.date}}</span>
          </li>
        ))}}
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
.author-page {{ max-width: 820px; margin: 0 auto; padding: 2rem 1rem; }}
.author-header {{ display: flex; align-items: center; gap: 2rem; margin-bottom: 3rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 2rem; }}
.author-info h1 {{ font-size: 2.5rem; margin: 0 0 1rem 0; color: #111827; }}
.bio {{ font-size: 1.1rem; line-height: 1.6; color: #4b5563; margin: 0; }}
.author-posts h2 {{ font-size: 1.5rem; margin-bottom: 1.5rem; color: #111827; }}
.post-list {{ list-style: none; padding: 0; }}
.post-list li {{ margin-bottom: 1.25rem; display: flex; flex-direction: column; gap: 0.25rem; }}
.post-list a {{ font-size: 1.2rem; font-weight: 600; color: #7c3aed; text-decoration: none; }}
.post-list a:hover {{ text-decoration: underline; }}
.date {{ font-size: 0.9rem; color: #6b7280; }}
</style>
