---
import BaseLayout from '../../layouts/BaseLayout.astro';

const modules = import.meta.glob('../../../content/posts/*.md', {{ eager: true }});
const posts = Object.values(modules).map(mod => (mod as any).frontmatter ?? {{}});

const authorCounts: Record<string, number> = {{}};
posts.forEach(p => {{
  if (p.author) {{
    authorCounts[p.author] = (authorCounts[p.author] || 0) + 1;
  }}
}});

const authors = Object.entries(authorCounts).map(([name, count]) => ({{
  name,
  count,
  slug: name.toLowerCase().replace(/\s+/g, '-')
}}));
---
<BaseLayout title="Authors | Notes Automate" description="Meet the expert contributors and researchers behind our guides and reviews.">
  <div class="authors-page">
    <h1>Our Authors</h1>
    <div class="author-grid">
      {{authors.map(author => (
        <div class="author-card">
          <h2><a href={`/author/${{author.slug}}/`}>{{author.name}}</a></h2>
          <p>{{author.count}} Articles Published</p>
        </div>
      ))}}
    </div>
  </div>
</BaseLayout>

<style>
.authors-page {{ max-width: 820px; margin: 0 auto; padding: 2rem 1rem; }}
h1 {{ font-size: 2.5rem; margin-bottom: 2rem; }}
.author-grid {{ display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 2rem; }}
.author-card {{ padding: 1.5rem; border: 1px solid #e5e7eb; border-radius: 8px; transition: border-color 0.2s; }}
.author-card:hover {{ border-color: #7c3aed; }}
.author-card h2 {{ margin: 0 0 0.5rem 0; font-size: 1.25rem; }}
.author-card a {{ color: #7c3aed; text-decoration: none; }}
.author-card a:hover {{ text-decoration: underline; }}
.author-card p {{ margin: 0; color: #6b7280; font-size: 0.9rem; }}
</style>
