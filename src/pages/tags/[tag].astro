---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface PostFrontmatter {
  title?: string;
  description?: string;
  tags?: string[];
  keywords?: string[];
  slug?: string;
  pubDate?: string;
  date?: string;
}

export async function getStaticPaths() {
  const modules = import.meta.glob<{ frontmatter: PostFrontmatter }>(
    '../../../content/posts/*.md',
    { eager: true }
  );

  const byTag = new Map<string, Array<{ title: string; description: string; slug: string; date: string }>>();

  for (const [path, mod] of Object.entries(modules)) {
    const fm = mod.frontmatter ?? {};
    const slug = fm.slug ?? path.split('/').pop()?.replace(/\.md$/, '') ?? '';
    const date = fm.pubDate ?? fm.date ?? '';
    const post = {
      title: fm.title ?? 'Untitled',
      description: fm.description ?? '',
      slug,
      date: typeof date === 'string' ? date : String(date),
    };
    // Support both `tags` and `keywords` frontmatter fields
    const tags = [...(fm.tags ?? []), ...(fm.keywords ?? [])];
    for (const raw of tags) {
      const tag = String(raw).toLowerCase().trim().replace(/\s+/g, '-').replace(/\//g, '-').replace(/[^a-z0-9\-]/g, '').replace(/-+/g, '-').replace(/^-|-$/g, '');
      if (!tag || tag.length < 2) continue;
      if (!byTag.has(tag)) byTag.set(tag, []);
      byTag.get(tag)!.push(post);
    }
  }

  return [...byTag.entries()]
    .filter(([, posts]) => posts.length >= 1)
    .map(([tag, posts]) => ({
      params: { tag },
      props: {
        tag,
        posts: posts.sort((a, b) => (b.date > a.date ? 1 : -1)),
      },
    }));
}

const { tag, posts } = Astro.props;
---
<BaseLayout title={`Guides tagged "${tag}" | Obsidian Plugins Guide`} description={`All Obsidian guides tagged "${tag}". ${posts.length} entries.`}>
  <div class="tag-archive">
    <p class="breadcrumb"><a href="/tags/">All tags</a> / <strong>{tag}</strong></p>
    <h1>Guides tagged "{tag}"</h1>
    <p class="hint">{posts.length} guide{posts.length === 1 ? '' : 's'}.</p>
    <ul class="post-list">
      {posts.map(p => (
        <li>
          <a href={`/posts/${p.slug}/`}>
            <h3>{p.title}</h3>
            {p.description && <p>{p.description}</p>}
            {p.date && <time>{p.date}</time>}
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
<style>
  .tag-archive { max-width: 820px; margin: 0 auto; padding: 2.5rem 1.25rem; }
  .breadcrumb { color: #6b7280; font-size: .9rem; margin-bottom: .75rem; }
  .breadcrumb a { color: #7c3aed; text-decoration: none; }
  .tag-archive h1 { font-size: 1.75rem; margin-bottom: .35rem; }
  .hint { color: #6b7280; margin-bottom: 1.5rem; }
  .post-list { list-style: none; padding: 0; display: grid; gap: 1.25rem; }
  .post-list li a {
    display: block; padding: 1.25rem; border: 1px solid #e5e7eb; border-radius: 8px;
    text-decoration: none; color: inherit; transition: box-shadow 0.2s;
  }
  .post-list li a:hover { box-shadow: 0 4px 12px rgba(124,58,237,0.10); border-color: #c4b5fd; }
  .post-list h3 { margin: 0 0 .35rem; color: #111827; }
  .post-list p { color: #6b7280; font-size: .95rem; margin: 0 0 .5rem; }
  .post-list time { color: #9ca3af; font-size: .85rem; }
</style>
