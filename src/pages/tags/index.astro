---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface PostFrontmatter {
  title?: string;
  tags?: string[];
  slug?: string;
}

const modules = import.meta.glob<{ frontmatter: PostFrontmatter }>(
  '../../../content/posts/*.md',
  { eager: true }
);

const tagCounts = new Map<string, number>();
for (const mod of Object.values(modules)) {
  const tags = mod.frontmatter?.tags ?? [];
  for (const raw of tags) {
    const tag = String(raw).toLowerCase().trim().replace(/\s+/g, '-');
    if (!tag) continue;
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCounts.entries()]
  .filter(([, n]) => n >= 1)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---
<BaseLayout title="All Tags | Obsidian Plugins Guide" description="Browse Obsidian plugin guides by tag.">
  <div class="tags-page">
    <h1>Browse by Tag</h1>
    <p class="hint">{tags.length} tags across all guides.</p>
    <ul class="tag-cloud">
      {tags.map(([tag, count]) => (
        <li><a href={`/tags/${tag}/`}>{tag} <span class="count">({count})</span></a></li>
      ))}
    </ul>
  </div>
</BaseLayout>
<style>
  .tags-page { max-width: 820px; margin: 0 auto; padding: 2.5rem 1.25rem; }
  .tags-page h1 { font-size: 2rem; margin-bottom: .5rem; }
  .hint { color: #6b7280; margin-bottom: 1.5rem; }
  .tag-cloud { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: .5rem; }
  .tag-cloud li a {
    display: inline-block; padding: .5rem .9rem; background: #f3eeff;
    border-radius: 999px; text-decoration: none; color: #111827; font-size: .95rem;
    transition: background 0.15s;
  }
  .tag-cloud li a:hover { background: #e9d5ff; }
  .tag-cloud .count { color: #6b7280; font-size: .85rem; margin-left: .25rem; }
</style>
